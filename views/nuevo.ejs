<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nuevo producto</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1>Registrar nuevo producto</h1>

    <!-- Al enviar, hace POST /productos -> el router inserta en la BD -->
    <form method="POST" action="/productos" class="formulario">
      <label>
        Nombre
        <!-- required: el navegador no deja enviar si está vacío -->
        <input type="text" name="nombre" required>
      </label>

      <label>
        Descripción
        <textarea name="descripcion" rows="3"></textarea>
      </label>

      <label>
        Cantidad
        <!-- min="0" evita stock negativo -->
        <input type="number" name="cantidad" min="0" value="0" required>
      </label>

      <label>
        Precio
        <!-- step="0.01" permite decimales (precio unitario) -->
        <input type="number" name="precio" min="0" step="0.01" value="0" required>
      </label>

      <div class="acciones">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a class="btn" href="/productos">Cancelar</a>
      </div>
    </form>
  </div>
</body>
</html>
