# ============================================================================
#  REFERENCIA para la app del Estudiante 1 (la que corre en la OTRA maquina).
#  Tu compañera debe poner estos valores en el .env de SU aplicacion para
#  conectarse a TU base de datos a traves de Tailscale.
#
#  DB_HOST = la IP que Tailscale le asigna a TU maquina
#            (la ves con el comando:  tailscale ip -4 )
# ============================================================================

DB_HOST=100.x.y.z        # <-- reemplazar por tu IP de Tailscale
DB_PORT=5432
DB_NAME=inventario
DB_USER=admin
DB_PASSWORD=secreto
PORT=3000
