<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reportes de Inventario</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">

    <header class="encabezado">
      <h1>Sistema de Reportes de Inventario</h1>
      <p class="sub">Estudiante 2 · Contenedor B · conectado a la base
        <code>inventario</code> por la red interna de Docker.</p>
    </header>

    <!-- ============ RESUMEN GENERAL (3 tarjetas) ============ -->
    <section class="tarjetas">
      <div class="tarjeta">
        <span class="tarjeta-num"><%= resumen.total_productos %></span>
        <span class="tarjeta-lbl">Productos registrados</span>
      </div>
      <div class="tarjeta">
        <span class="tarjeta-num"><%= resumen.unidades_totales %></span>
        <span class="tarjeta-lbl">Unidades en stock</span>
      </div>
      <div class="tarjeta tarjeta-valor">
        <span class="tarjeta-num">$<%= Number(resumen.valor_inventario).toFixed(2) %></span>
        <span class="tarjeta-lbl">Valor total del inventario</span>
      </div>
    </section>

    <div class="acciones">
      <a class="btn" href="/export/csv">Descargar CSV</a>
      <a class="btn btn-ghost" href="/api/resumen" target="_blank">Ver JSON (resumen)</a>
    </div>

    <!-- ============ REPORTE 1: STOCK BAJO ============ -->
    <section class="bloque">
      <h2>Alerta de bajo stock <small>(menos de 5 unidades)</small></h2>
      <% if (stockBajo.length === 0) { %>
        <p class="vacio">Ningun producto esta por debajo del minimo. </p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>ID</th><th>Nombre</th><th>Descripcion</th><th class="num">Stock</th><th class="num">Precio</th></tr>
          </thead>
          <tbody>
            <% stockBajo.forEach(p => { %>
              <tr>
                <td><%= p.id %></td>
                <td><%= p.nombre %></td>
                <td><%= p.descripcion %></td>
                <td class="num"><span class="badge-alerta"><%= p.cantidad %></span></td>
                <td class="num">$<%= Number(p.precio).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <!-- ============ REPORTE 2: TOP 5 POR VALOR ============ -->
    <section class="bloque">
      <h2>Top 5 productos por valor en inventario <small>(cantidad &times; precio)</small></h2>
      <% if (topValor.length === 0) { %>
        <p class="vacio">No hay productos registrados.</p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>#</th><th>Nombre</th><th class="num">Stock</th><th class="num">Precio</th><th class="num">Valor total</th></tr>
          </thead>
          <tbody>
            <% topValor.forEach((p, i) => { %>
              <tr>
                <td class="rank"><%= i + 1 %></td>
                <td><%= p.nombre %></td>
                <td class="num"><%= p.cantidad %></td>
                <td class="num">$<%= Number(p.precio).toFixed(2) %></td>
                <td class="num valor"><strong>$<%= Number(p.valor_total).toFixed(2) %></strong></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <footer class="pie">
      Endpoints JSON: <code>/api/stock-bajo</code> · <code>/api/top-valor</code> · <code>/api/resumen</code>
    </footer>

  </div>
</body>
</html>
