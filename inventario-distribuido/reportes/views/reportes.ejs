<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reportes de Inventario</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <span class="brand-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><rect x="7" y="10" width="3" height="8" rx="1"/><rect x="12" y="6" width="3" height="12" rx="1"/><rect x="17" y="13" width="3" height="5" rx="1"/></svg>
        </span>
        <span class="brand-text">
          <strong>Inventario</strong>
          <span>Panel de reportes</span>
        </span>
      </div>
      <span class="topbar-tag">Reportes</span>
    </div>
  </header>

  <main class="container">

    <div class="page-head">
      <h1>Reportes de inventario</h1>
      <p class="page-sub">Resumen del estado actual del inventario.</p>
    </div>

    <!-- ============ RESUMEN GENERAL (3 tarjetas) ============ -->
    <section class="tarjetas">
      <div class="tarjeta">
        <span class="tarjeta-num"><%= resumen.total_productos %></span>
        <span class="tarjeta-lbl">Productos registrados</span>
      </div>
      <div class="tarjeta">
        <span class="tarjeta-num"><%= resumen.unidades_totales %></span>
        <span class="tarjeta-lbl">Unidades en stock</span>
      </div>
      <div class="tarjeta tarjeta-valor">
        <span class="tarjeta-num">$<%= Number(resumen.valor_inventario).toFixed(2) %></span>
        <span class="tarjeta-lbl">Valor total del inventario</span>
      </div>
    </section>

    <div class="acciones">
      <a class="btn" href="/export/csv">Descargar CSV</a>
      <a class="btn btn-ghost" href="/api/resumen" target="_blank">Ver JSON (resumen)</a>
    </div>

    <!-- ============ REPORTE 1: STOCK BAJO ============ -->
    <section class="bloque">
      <h2>Alerta de bajo stock <small>(menos de 5 unidades)</small></h2>
      <% if (stockBajo.length === 0) { %>
        <p class="vacio">Ningun producto esta por debajo del minimo. </p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>ID</th><th>Nombre</th><th>Descripcion</th><th class="num">Stock</th><th class="num">Precio</th></tr>
          </thead>
          <tbody>
            <% stockBajo.forEach(p => { %>
              <tr>
                <td><%= p.id %></td>
                <td><%= p.nombre %></td>
                <td><%= p.descripcion %></td>
                <td class="num"><span class="badge-alerta"><%= p.cantidad %></span></td>
                <td class="num">$<%= Number(p.precio).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <!-- ============ REPORTE 2: TOP 5 POR VALOR ============ -->
    <section class="bloque">
      <h2>Top 5 productos por valor en inventario <small>(cantidad &times; precio)</small></h2>
      <% if (topValor.length === 0) { %>
        <p class="vacio">No hay productos registrados.</p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>#</th><th>Nombre</th><th class="num">Stock</th><th class="num">Precio</th><th class="num">Valor total</th></tr>
          </thead>
          <tbody>
            <% topValor.forEach((p, i) => { %>
              <tr>
                <td class="rank"><%= i + 1 %></td>
                <td><%= p.nombre %></td>
                <td class="num"><%= p.cantidad %></td>
                <td class="num">$<%= Number(p.precio).toFixed(2) %></td>
                <td class="num valor"><strong>$<%= Number(p.valor_total).toFixed(2) %></strong></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <!-- ============ EXTRA: GRAFICOS (valor por producto + por categoria) ============ -->
    <div class="grid-2">
      <section class="bloque">
        <h2>Valor por producto <small>(adicional · cantidad &times; precio)</small></h2>
        <% if (inventario.length === 0) { %>
          <p class="vacio">No hay productos registrados.</p>
        <% } else { %>
          <div class="grafico-wrap">
            <canvas id="graficoValor"></canvas>
          </div>
        <% } %>
      </section>

      <section class="bloque">
        <h2>Distribucion por categoria <small>(adicional · por valor)</small></h2>
        <% if (categorias.length === 0) { %>
          <p class="vacio">No hay productos registrados.</p>
        <% } else { %>
          <div class="grafico-wrap">
            <canvas id="graficoCategoria"></canvas>
          </div>
        <% } %>
      </section>
    </div>

    <!-- ============ EXTRA: INVENTARIO COMPLETO ============ -->
    <section class="bloque">
      <h2>Inventario completo <small>(adicional · <%= inventario.length %> producto<%= inventario.length === 1 ? '' : 's' %>)</small></h2>
      <% if (inventario.length === 0) { %>
        <p class="vacio">No hay productos registrados.</p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>ID</th><th>Nombre</th><th>Descripcion</th><th>Categoria</th><th class="num">Stock</th><th class="num">Precio</th><th class="num">Valor total</th></tr>
          </thead>
          <tbody>
            <% inventario.forEach(p => { %>
              <tr>
                <td><%= p.id %></td>
                <td><%= p.nombre %></td>
                <td><%= p.descripcion %></td>
                <td><%= p.categoria %></td>
                <td class="num"><%= p.cantidad %></td>
                <td class="num">$<%= Number(p.precio).toFixed(2) %></td>
                <td class="num valor"><strong>$<%= Number(p.valor_total).toFixed(2) %></strong></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

  </main>

  <!-- Chart.js para el grafico de barras (se carga desde CDN) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script>
    const datosInventario = <%- JSON.stringify(inventario.map(p => ({ nombre: p.nombre, valor: Number(p.valor_total) }))) %>;
    const canvas = document.getElementById('graficoValor');
    if (canvas && datosInventario.length && window.Chart) {
      new Chart(canvas, {
        type: 'bar',
        data: {
          labels: datosInventario.map(d => d.nombre),
          datasets: [{
            label: 'Valor en inventario ($)',
            data: datosInventario.map(d => d.valor),
            backgroundColor: '#1d4ed8',
            borderRadius: 6,
            maxBarThickness: 46
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { callback: v => '$' + v } },
            x: { ticks: { maxRotation: 45, minRotation: 0, autoSkip: false } }
          }
        }
      });
    }

    // Grafico de dona: distribucion del valor del inventario por categoria.
    const datosCategoria = <%- JSON.stringify(categorias.map(c => ({ categoria: c.categoria, valor: Number(c.valor_total) }))) %>;
    const canvasCat = document.getElementById('graficoCategoria');
    if (canvasCat && datosCategoria.length && window.Chart) {
      const colores = ['#1d4ed8','#0e7490','#0f766e','#7c3aed','#db2777','#ea580c','#ca8a04','#475569','#16a34a'];
      new Chart(canvasCat, {
        type: 'doughnut',
        data: {
          labels: datosCategoria.map(d => d.categoria),
          datasets: [{
            data: datosCategoria.map(d => d.valor),
            backgroundColor: datosCategoria.map((d, i) => colores[i % colores.length]),
            borderWidth: 2,
            borderColor: '#fff'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'right', labels: { boxWidth: 12, font: { size: 11 } } } }
        }
      });
    }
  </script>
</body>
</html>
